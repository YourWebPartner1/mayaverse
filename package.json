{
  "name": "mayaverse",
  "version": "1.0.0",
  "description": "MAYAVERSE — Premium digital marketing agency for passionate entrepreneurs. Website Design, SEO, SEM, Branding, Google Business, Content Writing, and more.",
  "author": "MayaVerse",
  "license": "MIT",
  "private": true,
  "homepage": "https://mayaverse.io",
  "keywords": [
    "cinematic",
    "landing-page",
    "cyberpunk",
    "gsap",
    "vanilla-js",
    "web-experience",
    "dark-mode",
    "parallax",
    "volcanic",
    "premium"
  ],
  "scripts": {
    "dev": "npx -y serve . -l 3000",
    "start": "npx -y serve . -l 8080",
    "preview": "npx -y serve . -l 5000 --cors",
    "lint:html": "npx -y html-validate index.html",
    "lint:css": "npx -y stylelint style.css",
    "format": "npx -y prettier --write index.html style.css script.js"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "Edge >= 90"
  ],
  "devDependencies": {
    "serve": "^14.2.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/mayaverse.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/mayaverse/issues"
  }
}
